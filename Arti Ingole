<!DOCTYPE html>
<html>
<head>
    <title>Bus Ticket Booking System</title>
    <style>
        body{
            font-family: Arial, sans-serif;
            background:#f4f4f4;
            display:flex;
            justify-content:center;
            align-items:center;
            height:100vh;
        }

        .container{
            background:white;
            padding:20px;
            width:400px;
            border-radius:10px;
            box-shadow:0 0 10px gray;
        }

        h2{
            text-align:center;
        }

        input, select, button{
            width:100%;
            padding:10px;
            margin:8px 0;
        }

        button{
            background:green;
            color:white;
            border:none;
            cursor:pointer;
        }

        button:hover{
            background:darkgreen;
        }

        #result{
            margin-top:15px;
            padding:10px;
            background:#eef;
        }
    </style>
</head>
<body>

<div class="container">
    <h2>Bus Ticket Booking System</h2>

    <input type="text" id="name" placeholder="Passenger Name">

    <input type="number" id="age" placeholder="Age">

    <select id="ticketType">
        <option value="">Select Ticket Type</option>
        <option value="300">Regular - ₹300</option>
        <option value="500">Sleeper - ₹500</option>
        <option value="800">AC - ₹800</option>
    </select>

    <input type="number" id="tickets" placeholder="Number of Tickets">

    <button onclick="bookTicket()">Book Ticket</button>

    <div id="result"></div>
</div>

<script>
function bookTicket() {

    let name = document.getElementById("name").value;
    let age = parseInt(document.getElementById("age").value);
    let ticketPrice = parseInt(document.getElementById("ticketType").value);
    let tickets = parseInt(document.getElementById("tickets").value);

    if(name === "" || age <= 0 || !ticketPrice || tickets <= 0){
        document.getElementById("result").innerHTML =
        "Please fill all fields properly.";
        return;
    }

    let totalAmount = ticketPrice * tickets;
    let discount = 0;

    if(age < 5){
        discount = totalAmount;
    }
    else if(age >= 5 && age <= 12){
        discount = totalAmount * 0.50;
    }
    else if(age >= 60){
        discount = totalAmount * 0.30;
    }

    let payableAmount = totalAmount - discount;

   document.getElementById("result").innerHTML =
"<h3>Ticket Details </h3>" +
"<b>Passenger Name:</b> " + name + "<br>" +
"<b>Age:</b> " + age + "<br>" +
"<b>Ticket Price:</b> ₹" + ticketPrice + "<br>" +
"<b>Number of Tickets:</b> " + tickets + "<br>" +
"<b>Total Amount:</b> ₹" + totalAmount + "<br>" +
"<b>Discount:</b> ₹" + discount + "<br>" +
"<b> Payable Amount:</b> ₹" + payableAmount;
}
</script>

</body>
</html>

